@page
@model LoginModel
@{
    ViewData["Title"] = "Log In";
    ViewData["BodyClass"] = "cassetted-landing";
}

<div class="auth-page">
    <div class="auth-card auth-card--login">

        <a href="/" class="auth-back" aria-label="Back to home">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                <path d="M19 12H5M5 12l7 7M5 12l7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
        </a>

        <h1 class="auth-title">See what you've missed.</h1>
        <p class="auth-subtitle">Log in to catch up on your friends' latest reviews and recommendations.</p>

        <form id="loginForm" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="auth-error" role="alert"></div>

            <div class="auth-field">
                <div class="auth-input-wrap">
                    <span class="auth-icon-left">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                            <rect x="2" y="4" width="20" height="16" rx="2" stroke="currentColor" stroke-width="1.8" />
                            <path d="M2 7l10 7 10-7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                        </svg>
                    </span>
                    <input asp-for="Input.Email" type="email" class="auth-input has-icon-l"
                           placeholder="Email" autocomplete="username" aria-required="true" />
                </div>
                <span asp-validation-for="Input.Email" class="auth-field-error"></span>
            </div>

            <div class="auth-field">
                <div class="auth-input-wrap">
                    <span class="auth-icon-left">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                            <rect x="5" y="11" width="14" height="10" rx="2" stroke="currentColor" stroke-width="1.8" />
                            <path d="M8 11V7a4 4 0 0 1 8 0v4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                        </svg>
                    </span>
                    <input asp-for="Input.Password" type="password" id="loginPwd"
                           class="auth-input has-icon-l has-icon-r"
                           placeholder="Password" autocomplete="current-password" aria-required="true" />
                    <button type="button" class="auth-icon-right" onclick="togglePwd('loginPwd')" aria-label="Toggle password visibility">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" stroke="currentColor" stroke-width="1.8" />
                            <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.8" />
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="Input.Password" class="auth-field-error"></span>
            </div>

            <button type="submit" class="auth-submit">Log In</button>
        </form>

        <p class="auth-switch">Don't have an account yet? <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Sign up</a></p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePwd(id) {
            var inp = document.getElementById(id);
            inp.type = inp.type === 'password' ? 'text' : 'password';
        }
    </script>
}
