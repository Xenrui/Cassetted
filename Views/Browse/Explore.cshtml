@model ExploreViewModel
@{
    ViewData["Title"] = "Explore";
    ViewData["BodyClass"] = "cassetted-landing";
    ViewData["ActiveNav"] = "Browse";
}

@section Styles {
    <link rel="stylesheet" href="~/css/browse.css" asp-append-version="true" />
}

<div class="c-browse">

    <p class="c-explore__breadcrumb">Browse &rsaquo; Explore</p>

    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="javascript:history.back()" class="c-explore__back d-inline-flex align-items-center justify-content-center" aria-label="Go back">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                <path d="M19 12H5M5 12l7 7M5 12l7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
        </a>
        <h1 class="c-explore__heading">Explore</h1>
    </div>

    <form method="get" class="mb-4">
        @if (Model.CategoryId.HasValue)
        {
            <input type="hidden" name="category" value="@Model.CategoryId" />
        }
        <select name="sort" class="c-explore__sort" onchange="this.form.submit()">
            <option value="rating-desc" selected="@(Model.SortBy == "rating-desc" ? "selected" : null)">Ratings: Highest to Lowest</option>
            <option value="rating-asc"  selected="@(Model.SortBy == "rating-asc"  ? "selected" : null)">Ratings: Lowest to Highest</option>
            <option value="reviews-desc" selected="@(Model.SortBy == "reviews-desc" ? "selected" : null)">Most Reviews</option>
            <option value="reviews-asc"  selected="@(Model.SortBy == "reviews-asc"  ? "selected" : null)">Fewest Reviews</option>
        </select>
    </form>

    @if (!Model.Items.Any())
    {
        <p class="text-muted text-center py-5">No items to explore yet.</p>
    }
    else
    {
        <div class="c-explore__grid">
            @foreach (var item in Model.Items)
            {
                <a class="c-item-card" asp-controller="Browse" asp-action="Item" asp-route-id="@item.Id">
                    <span class="c-item-card__badge c-badge c-badge--@item.BadgeSlug rounded-pill">@item.CategoryName</span>
                    <h3 class="c-item-card__title">@item.Name</h3>
                    <div class="c-item-card__rating d-flex align-items-center gap-2 mb-2">
                        <span class="c-item-card__rating-star">&#9733;</span>
                        <span>@item.AverageRating.ToString("0.0")/5 Rating</span>
                    </div>
                    <div class="c-item-card__stats">
                        @item.CommentCount recent discussions<br />
                        @item.ReviewCount overall reviews
                    </div>
                </a>
            }
        </div>
    }

</div>
