@model ItemDetailViewModel
@{
    ViewData["Title"] = Model.Name;
    ViewData["BodyClass"] = "cassetted-landing";
    ViewData["ActiveNav"] = "Browse";
    var badgeClass = Model.CategoryName.ToLower().Replace(" ", "");
    int reviewCount = Model.Reviews.Count;
}

@section Styles {
    <link rel="stylesheet" href="~/css/browse.css" asp-append-version="true" />
}

<div class="c-browse">

    <!-- ── Navigation strip ── -->
    <div class="d-flex align-items-center gap-3 mb-2">
        <a href="javascript:history.back()" class="c-explore__back d-inline-flex align-items-center justify-content-center" aria-label="Go back">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                <path d="M19 12H5M5 12l7 7M5 12l7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
        </a>
        <p class="c-explore__breadcrumb mb-0">
            <a asp-controller="Browse" asp-action="Index" style="color:inherit;text-decoration:none;">Browse</a>
            &rsaquo; <a asp-controller="Browse" asp-action="Explore" style="color:inherit;text-decoration:none;">Explore</a>
            &rsaquo; @Model.Name
        </p>
    </div>

    <!-- ── Hero ── -->
    <div class="c-browse-item__hero">
        <span class="c-badge c-badge--@badgeClass rounded-pill">@Model.CategoryName</span>
        <h1 class="c-browse-item__title">@Model.Name</h1>

        <div class="c-browse-item__stats">
            <div class="c-browse-item__stat">
                <div class="c-browse-item__stat-num">
                    <span class="c-browse-item__stat-star">&#9733;</span>
                    @Model.AverageRating.ToString("0.0")
                </div>
                <span class="c-browse-item__stat-label">Rating</span>
            </div>
            <div class="c-browse-item__stat">
                <div class="c-browse-item__stat-num">@Model.ReviewCount</div>
                <span class="c-browse-item__stat-label">Reviews</span>
            </div>
            <div class="c-browse-item__stat">
                <div class="c-browse-item__stat-num">@Model.CommentCount</div>
                <span class="c-browse-item__stat-label">Discussions</span>
            </div>
        </div>

        <button class="c-browse-item__write-btn" data-bs-toggle="modal" data-bs-target="#reviewModal">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none">
                <path d="M12 20h9M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            Write a Review
        </button>
    </div>

    <!-- ── Community Reviews ── -->
    @if (!Model.Reviews.Any())
    {
        <p class="text-muted text-center py-5">No reviews yet. Be the first!</p>
    }
    else
    {
        <h2 class="c-browse-item__reviews-heading">
            Community Reviews
            <span class="c-browse-item__reviews-count">@reviewCount</span>
        </h2>
        <hr class="c-browse-item__divider" />

        <div class="c-browse-community__reviews">
            @foreach (var review in Model.Reviews)
            {
                var revBadgeClass = review.CategoryName.ToLower().Replace(" ", "");
                int filled = (int)Math.Round(review.Rating);
                <div class="c-review-card mb-3" data-href="@Url.Action("Details", "Review", new { id = review.Id })">
                    <div class="c-review-card__header d-flex align-items-start justify-content-between mb-2">
                        <div class="d-flex align-items-start gap-3">
                            <div class="c-avatar c-avatar--sm flex-shrink-0">
                                <svg viewBox="0 0 40 40" fill="none">
                                    <circle cx="20" cy="20" r="20" fill="#2a5045" />
                                    <circle cx="20" cy="15" r="6" fill="#3d7060" />
                                    <path d="M7 36c0-7 5.8-12 13-12s13 5 13 12" fill="#3d7060" />
                                </svg>
                            </div>
                            <div class="d-flex flex-column">
                                <div class="c-review-card__meta d-flex align-items-center">
                                    <span class="c-review-card__username">@review.UserDisplayName</span>
                                    <span class="c-review-card__sep mx-1">·</span>
                                    <span class="c-review-card__date">@review.CreatedAt.ToString("MMM d, yyyy")</span>
                                </div>
                                <div class="c-stars mt-1">
                                    @Html.Raw(new string('★', filled))
                                    @if (filled < 5)
                                    {
                                        <span class="c-star--empty">@Html.Raw(new string('★', 5 - filled))</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(review.Title))
                    {
                        <h3 class="c-review-card__title">@review.Title</h3>
                    }
                    <p class="c-review-card__body">@review.Body</p>
                    <div class="c-review-card__actions d-flex">
                        <button class="c-action-btn d-inline-flex align-items-center gap-2" style="color:rgba(255,120,140,.65)">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                            Like@(review.LikeCount > 0 ? $" · {review.LikeCount}" : "")
                        </button>
                        <button class="c-action-btn d-inline-flex align-items-center gap-2">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                            Reply@(review.CommentCount > 0 ? $" · {review.CommentCount}" : "")
                        </button>
                    </div>
                </div>
            }
        </div>
    }

</div>

<partial name="_ReviewModal" />
