@model FeedViewModel
@{
    ViewData["Title"] = "Feed";
    ViewData["BodyClass"] = "cassetted-landing";
    ViewData["ActiveNav"] = "Feed";
}

@section Styles {
    <link rel="stylesheet" href="~/css/feed.css" asp-append-version="true" />
}

<div class="c-feed">
    <div class="c-feed__grid">

        <!-- ── Left: Main feed ── -->
        <div class="c-feed__main">

            <!-- New review prompt -->
            <div class="c-new-review d-flex align-items-center" role="button"
                 data-bs-toggle="modal" data-bs-target="#reviewModal">
                <div class="c-avatar">
                    <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="20" cy="20" r="20" fill="#2a5045" />
                        <circle cx="20" cy="15" r="6" fill="#3d7060" />
                        <path d="M7 36c0-7 5.8-12 13-12s13 5 13 12" fill="#3d7060" />
                    </svg>
                </div>
                <input type="text" class="c-new-review__input" placeholder="Watched something new?" readonly tabindex="-1" />
            </div>

            <!-- Tab switcher -->
            <div class="c-feed-tabs d-flex">
                <a href="?tab=foryou" class="c-feed-tab flex-grow-1 @(Model.ActiveTab == "foryou" ? "c-feed-tab--active" : "")">For You</a>
                <a href="?tab=friends" class="c-feed-tab flex-grow-1 @(Model.ActiveTab == "friends" ? "c-feed-tab--active" : "")">Friends Only</a>
            </div>

            @if (!Model.Reviews.Any())
            {
                <p class="text-muted text-center py-5">
                    @(Model.ActiveTab == "friends" ? "No reviews from people you follow yet." : "No reviews yet. Be the first to share!")
                </p>
            }
            else
            {
                @foreach (var review in Model.Reviews)
                {
                    var badgeClass = review.CategoryName.ToLower().Replace(" ", "");
                    int filled = (int)Math.Round(review.Rating);
                    <div class="c-review-card" data-href="@Url.Action("Details", "Review", new { id = review.Id })">
                        <div class="c-review-card__header d-flex align-items-center justify-content-between">
                            <div class="c-review-card__user d-flex align-items-center">
                                <div class="c-avatar c-avatar--sm">
                                    <svg viewBox="0 0 40 40" fill="none">
                                        <circle cx="20" cy="20" r="20" fill="#2a5045" />
                                        <circle cx="20" cy="15" r="6" fill="#3d7060" />
                                        <path d="M7 36c0-7 5.8-12 13-12s13 5 13 12" fill="#3d7060" />
                                    </svg>
                                </div>
                                <div class="c-review-card__meta d-flex align-items-center">
                                    <a class="c-review-card__username" asp-controller="Profile" asp-action="Index" asp-route-userId="@review.UserId">@review.UserDisplayName</a>
                                    <span class="c-review-card__sep">·</span>
                                    <span class="c-review-card__date">@review.CreatedAt.ToString("MM/dd/yyyy")</span>
                                </div>
                            </div>
                            <span class="c-badge c-badge--@badgeClass rounded-pill">@review.CategoryName</span>
                        </div>
                        <div class="c-stars">
                            @Html.Raw(new string('★', filled))
                            @if (filled < 5)
                            {
                                <span class="c-star--empty">@Html.Raw(new string('★', 5 - filled))</span>
                            }
                        </div>
                        <h3 class="c-review-card__title"><a asp-controller="Review" asp-action="Details" asp-route-id="@review.Id">@review.ItemName</a></h3>
                        <p class="c-review-card__body">@review.Body</p>
                        <div class="c-review-card__actions d-flex">
                            <button class="c-action-btn c-like-btn d-inline-flex align-items-center gap-2 @(review.IsLikedByCurrentUser ? "c-like-btn--liked" : "")"
                                    data-review-id="@review.Id">
                                <svg class="c-like-btn__icon" width="16" height="16" viewBox="0 0 24 24" fill="@(review.IsLikedByCurrentUser ? "currentColor" : "none")">
                                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                                </svg>
                                Like<span class="c-like-count">@(review.LikeCount > 0 ? $" · {review.LikeCount}" : "")</span>
                            </button>
                            <button class="c-action-btn d-inline-flex align-items-center gap-2">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                                </svg>
                                Reply@(review.CommentCount > 0 ? $" · {review.CommentCount}" : "")
                            </button>
                        </div>
                    </div>
                }
            }

        </div>

        <!-- ── Right: Trending ── -->
        <aside class="c-feed__sidebar">
            <div class="c-trending">
                <div class="c-trending__header d-flex align-items-center">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                        <polyline points="23 6 13.5 15.5 8.5 10.5 1 18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                        <polyline points="17 6 23 6 23 12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    <span>Trending</span>
                </div>

                <div class="c-trending__list d-flex flex-column">
                    @if (!Model.TrendingItems.Any())
                    {
                        <p class="text-muted small text-center py-2">Nothing trending yet.</p>
                    }
                    else
                    {
                        @for (int i = 0; i < Model.TrendingItems.Count; i++)
                        {
                            var item = Model.TrendingItems[i];
                            var trendBadgeClass = item.CategoryName.ToLower().Replace(" ", "");
                            int trendFilled = (int)Math.Round(item.AverageRating);
                            <div class="c-trending__item d-flex align-items-center">
                                <span class="c-trending__rank">@(i + 1)</span>
                                <div class="c-trending__info">
                                    <div class="c-trending__title">@item.Name</div>
                                    <div class="c-stars c-stars--sm">
                                        @Html.Raw(new string('★', trendFilled))
                                        @if (trendFilled < 5)
                                        {
                                            <span class="c-star--empty">@Html.Raw(new string('★', 5 - trendFilled))</span>
                                        }
                                    </div>
                                </div>
                                <span class="c-badge c-badge--@trendBadgeClass rounded-pill">@item.CategoryName</span>
                            </div>
                        }
                    }
                </div>
            </div>
        </aside>

    </div>
</div>

<partial name="_ReviewModal" />
