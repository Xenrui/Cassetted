@{
    ViewData["Title"] = "Home";
    ViewData["BodyClass"] = "cassetted-landing";
}

@section Styles {
    <link rel="stylesheet" href="~/css/landing.css" asp-append-version="true" />
}

<section class="c-hero d-flex align-items-center justify-content-center">
    <div class="c-hero__content d-flex flex-column align-items-center">
        <h1 class="c-hero__title d-flex flex-column">
            <span class="c-hero__line">Your entertainment,</span>
            <span class="c-hero__line">on the record.</span>
        </h1>
        <div class="c-hero__cassette">
            <img src="~/images/logo.png" alt="Cassetted" class="c-hero__cassette-img" />
        </div>
        <a asp-area="Identity" asp-page="/Account/Register" class="c-hero__cta">Join the Community</a>
    </div>
</section>
