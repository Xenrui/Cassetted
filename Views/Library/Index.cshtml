@model LibraryViewModel
@{
    ViewData["Title"] = $"{Model.UserDisplayName}'s Library";
    ViewData["BodyClass"] = "cassetted-landing";
    ViewData["ActiveNav"] = "Library";
    int reviewCount = Model.RecentReviews.Count;
    int favCount = Model.Favorites.Count;
}

@section Styles {
    <link rel="stylesheet" href="~/css/library.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/feed.css" asp-append-version="true" />
}

<div class="c-library">

    <!-- ── Header ── -->
    <div class="c-library__header d-flex align-items-end justify-content-between gap-4 mb-5">
        <div>
            <h1 class="c-library__username">
                <span class="c-library__username-accent">@Model.UserDisplayName</span>'s Library
            </h1>
            <div class="c-library__meta d-flex align-items-center gap-2">
                <span>@reviewCount review@(reviewCount != 1 ? "s" : "")</span>
                <span class="c-library__meta-sep">·</span>
                <span>@favCount saved</span>
            </div>
        </div>
        <button class="c-library__write-btn d-inline-flex align-items-center gap-2" data-bs-toggle="modal" data-bs-target="#reviewModal">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
            </svg>
            Write a Review
        </button>
    </div>

    <!-- ── Recent Reviews ── -->
    <section class="c-lib-section mb-5">
        <div class="c-lib-section__heading d-flex align-items-center gap-3 mb-4">
            <h2 class="c-lib-section__title">Recent Reviews</h2>
            @if (reviewCount > 0)
            {
                <span class="c-lib-section__count">@reviewCount total</span>
            }
            <div class="c-lib-section__line"></div>
        </div>

        @if (!Model.RecentReviews.Any())
        {
            <div class="c-lib-empty">
                <span class="c-lib-empty__icon">
                    <svg width="44" height="44" viewBox="0 0 24 24" fill="none">
                        <path d="M12 20h9M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </span>
                <p class="c-lib-empty__text">You haven't reviewed anything yet.<br />Start building your collection.</p>
                <button class="c-lib-empty__btn d-inline-flex align-items-center gap-2" data-bs-toggle="modal" data-bs-target="#reviewModal">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none">
                        <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
                    </svg>
                    Write your first review
                </button>
            </div>
        }
        else
        {
            <div class="c-lib-track d-flex gap-3">
                @foreach (var review in Model.RecentReviews)
                {
                    <div class="c-lib-card"
                         data-href="@Url.Action("Details", "Review", new { id = review.Id })">
                        <span class="c-badge c-badge--@review.BadgeSlug rounded-pill c-lib-card__badge">@review.CategoryName</span>
                        <div class="c-lib-card__top">
                            <div class="c-lib-card__stars">
                                @Html.Raw(new string('★', review.FilledStars))
                                @if (review.FilledStars < 5)
                                {
                                    <span class="c-star--empty">@Html.Raw(new string('★', 5 - review.FilledStars))</span>
                                }
                            </div>
                            <h3 class="c-lib-card__title">@review.ItemName</h3>
                        </div>
                        <div class="c-lib-card__body-wrap">
                            <p class="c-lib-card__body">@review.Body</p>
                        </div>
                        <div class="c-lib-card__footer d-flex align-items-center justify-content-between">
                            <span class="c-lib-card__date">@review.CreatedAt.ToString("MMM d, yyyy")</span>
                            <div class="d-flex align-items-center gap-2" onclick="event.stopPropagation()">
                                @if (review.FavoriteCount > 0)
                                {
                                    <span class="c-lib-card__fav-meta d-inline-flex align-items-center gap-1" title="@review.FavoriteCount saved this">
                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor">
                                            <path d="M6 3h12a1 1 0 0 1 1 1v17l-7-4-7 4V4a1 1 0 0 1 1-1z" />
                                        </svg>
                                        @review.FavoriteCount
                                    </span>
                                }
                                <div class="dropdown">
                                    <button class="c-lib-card__menu-btn" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Options">&#8942;</button>
                                    <ul class="dropdown-menu dropdown-menu-end c-post-card__dropdown">
                                        <li><a class="dropdown-item" asp-controller="Review" asp-action="Edit" asp-route-id="@review.Id">Edit</a></li>
                                        <li>
                                            <form asp-controller="Review" asp-action="Delete" asp-route-id="@review.Id" method="post">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="dropdown-item c-post-card__dropdown-delete">Delete</button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </section>

    <!-- ── Saved (Favorites) ── -->
    <section class="c-lib-section mb-5">
        <div class="c-lib-section__heading d-flex align-items-center gap-3 mb-4">
            <h2 class="c-lib-section__title">Saved</h2>
            @if (favCount > 0)
            {
                <span class="c-lib-section__count">@favCount total</span>
            }
            <div class="c-lib-section__line"></div>
        </div>

        @if (!Model.Favorites.Any())
        {
            <div class="c-lib-empty">
                <span class="c-lib-empty__icon">
                    <svg width="44" height="44" viewBox="0 0 24 24" fill="none">
                        <path d="M6 3h12a1 1 0 0 1 1 1v17l-7-4-7 4V4a1 1 0 0 1 1-1z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
                    </svg>
                </span>
                <p class="c-lib-empty__text">Nothing saved yet.<br />Tap the bookmark on any review you want to keep.</p>
            </div>
        }
        else
        {
            <div class="c-lib-track d-flex gap-3">
                @foreach (var fav in Model.Favorites)
                {
                    <div class="c-lib-card c-lib-card--fav"
                         data-href="@Url.Action("Details", "Review", new { id = fav.ReviewId })">
                        <span class="c-badge c-badge--@fav.BadgeSlug rounded-pill c-lib-card__badge">@fav.CategoryName</span>
                        <div class="c-lib-card__top">
                            <div class="c-lib-card__stars">
                                @Html.Raw(new string('★', fav.FilledStars))
                                @if (fav.FilledStars < 5)
                                {
                                    <span class="c-star--empty">@Html.Raw(new string('★', 5 - fav.FilledStars))</span>
                                }
                            </div>
                            <h3 class="c-lib-card__title">@fav.ItemName</h3>
                            <a class="c-lib-card__author"
                               asp-controller="Profile" asp-action="Index" asp-route-userId="@fav.AuthorUserId"
                               onclick="event.stopPropagation()">
                                by @fav.AuthorDisplayName
                            </a>
                        </div>
                        <div class="c-lib-card__body-wrap">
                            <p class="c-lib-card__body">@fav.Body</p>
                        </div>
                        <div class="c-lib-card__footer d-flex align-items-center justify-content-between">
                            <span class="c-lib-card__date">Saved @fav.SavedAt.ToString("MMM d, yyyy")</span>
                            <span class="c-lib-card__fav-icon" aria-hidden="true">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M6 3h12a1 1 0 0 1 1 1v17l-7-4-7 4V4a1 1 0 0 1 1-1z" />
                                </svg>
                            </span>
                        </div>
                    </div>
                }
            </div>
        }
    </section>

</div>

<partial name="_ReviewModal" />
