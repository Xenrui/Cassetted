@model ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
    ViewData["BodyClass"] = "cassetted-landing";
}

@section Styles {
    <link rel="stylesheet" href="~/css/settings.css" asp-append-version="true" />
}

<div class="c-settings">

    <!-- ── Header ── -->
    <div class="c-settings__header">
        <a asp-action="Settings" class="c-settings__back">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                <path d="M19 12H5M5 12l7 7M5 12l7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            Settings
        </a>
        <h1 class="c-settings__title">Change Password</h1>
        <p class="c-settings__subtitle">Your password must be at least 6 characters.</p>
    </div>

    <!-- ── Error summary ── -->
    @if (!ViewData.ModelState.IsValid && ViewData.ModelState[string.Empty]?.Errors.Count > 0)
    {
        <div class="c-settings__saved c-settings__saved--error d-flex align-items-center gap-2 py-2 px-3 mb-4" role="alert">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.8" />
                <line x1="12" y1="8" x2="12" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                <line x1="12" y1="16" x2="12.01" y2="16" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            </svg>
            @ViewData.ModelState[string.Empty]!.Errors[0].ErrorMessage
        </div>
    }

    <form asp-action="ChangePassword" method="post" novalidate>
        @Html.AntiForgeryToken()

        <div class="c-settings__section">

            <div class="c-settings__section-header">
                <h2 class="c-settings__section-title">Password</h2>
            </div>

            <div class="c-settings__section-body">

                <!-- Current password -->
                <div class="c-settings__field">
                    <label class="c-settings__label" asp-for="CurrentPassword">Current Password</label>
                    <input class="c-settings__input @(ViewData.ModelState["CurrentPassword"]?.Errors.Count > 0 ? "is-invalid" : "")"
                           asp-for="CurrentPassword"
                           type="password"
                           placeholder="Enter your current password"
                           autocomplete="current-password" />
                    <span asp-validation-for="CurrentPassword" class="c-settings__error"></span>
                </div>

                <!-- Divider -->
                <hr class="c-settings__divider my-3" />

                <!-- New password -->
                <div class="c-settings__field">
                    <label class="c-settings__label" asp-for="NewPassword">New Password</label>
                    <input class="c-settings__input @(ViewData.ModelState["NewPassword"]?.Errors.Count > 0 ? "is-invalid" : "")"
                           asp-for="NewPassword"
                           type="password"
                           id="new-password"
                           placeholder="At least 6 characters"
                           autocomplete="new-password" />
                    <span asp-validation-for="NewPassword" class="c-settings__error"></span>
                </div>

                <!-- Confirm new password -->
                <div class="c-settings__field mb-0">
                    <label class="c-settings__label" asp-for="ConfirmNewPassword">Confirm New Password</label>
                    <input class="c-settings__input @(ViewData.ModelState["ConfirmNewPassword"]?.Errors.Count > 0 ? "is-invalid" : "")"
                           asp-for="ConfirmNewPassword"
                           type="password"
                           id="confirm-password"
                           placeholder="Repeat your new password"
                           autocomplete="new-password" />
                    <span asp-validation-for="ConfirmNewPassword" class="c-settings__error"></span>
                </div>

            </div>

            <hr class="c-settings__divider" />

            <div class="px-4 pb-4">
                <button type="submit" class="c-settings__save-btn">UPDATE PASSWORD</button>
            </div>

        </div>

    </form>

</div>

@section Scripts {
    <script>
        // Live match indicator on confirm field
        const newPw = document.getElementById('new-password');
        const confirmPw = document.getElementById('confirm-password');

        function checkMatch() {
            if (!confirmPw.value) { confirmPw.style.boxShadow = ''; return; }
            const match = newPw.value === confirmPw.value;
            confirmPw.style.boxShadow = match
                ? '0 0 0 2px rgba(77,196,164,.45)'
                : '0 0 0 2px rgba(255,80,80,.4)';
        }

        if (newPw && confirmPw) {
            newPw.addEventListener('input', checkMatch);
            confirmPw.addEventListener('input', checkMatch);
        }
    </script>
}
