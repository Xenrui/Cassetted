@model ProfileViewModel
@{
    ViewData["Title"] = $"{Model.DisplayName}'s Profile";
    ViewData["BodyClass"] = "cassetted-landing";
}

@section Styles {
    <link rel="stylesheet" href="~/css/profile.css" asp-append-version="true" />
}

<div class="c-profile">

    <!-- ── Header card ── -->
    <div class="c-profile-header mb-4">
        <div class="d-flex align-items-start gap-4">

            <!-- Avatar -->
            <div class="c-profile-header__avatar">
                <svg viewBox="0 0 108 108" fill="none">
                    <rect width="108" height="108" fill="#1d4a3e" />
                    <circle cx="54" cy="42" r="20" fill="#2e6b58" />
                    <path d="M10 108c0-24 19.7-42 44-42s44 18 44 42" fill="#2e6b58" />
                </svg>
            </div>

            <!-- Name, bio -->
            <div class="c-profile-header__info">
                <div class="c-profile-header__name-row d-flex align-items-center gap-2 mb-2">
                    <h1 class="c-profile-header__name">@Model.DisplayName</h1>
                    @if (Model.IsOwnProfile)
                    {
                        <a class="c-profile-header__edit-btn" asp-controller="Profile" asp-action="Settings" title="Edit profile">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                        </a>
                    }
                    else if (Model.IsFollowing)
                    {
                        <form asp-action="Unfollow" method="post" class="ms-2">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="userId" value="@Model.UserId" />
                            <button type="submit" class="c-profile-header__follow-btn c-profile-header__follow-btn--unfollow">
                                Following
                            </button>
                        </form>
                    }
                    else
                    {
                        <form asp-action="Follow" method="post" class="ms-2">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="userId" value="@Model.UserId" />
                            <button type="submit" class="c-profile-header__follow-btn c-profile-header__follow-btn--follow">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none">
                                    <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
                                </svg>
                                Follow
                            </button>
                        </form>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.Bio))
                {
                    <p class="c-profile-header__bio">@Model.Bio</p>
                }
                else if (Model.IsOwnProfile)
                {
                    <p class="c-profile-header__bio c-profile-header__bio-empty">No bio yet — add one in Settings.</p>
                }
            </div>

            <!-- Stats -->
            <div class="c-profile-header__stats d-flex align-items-start">
                <div class="c-profile-stat d-flex flex-column align-items-center gap-1">
                    <span class="c-profile-stat__num">@Model.ReviewCount</span>
                    <span class="c-profile-stat__label">Reviews</span>
                </div>
                <div class="c-profile-stat d-flex flex-column align-items-center gap-1">
                    <span class="c-profile-stat__num">@Model.FollowingCount</span>
                    <span class="c-profile-stat__label">Following</span>
                </div>
                <div class="c-profile-stat d-flex flex-column align-items-center gap-1">
                    <span class="c-profile-stat__num">@Model.FollowerCount</span>
                    <span class="c-profile-stat__label">Followers</span>
                </div>
            </div>

        </div>
    </div>

    <!-- ── Insight cards ── -->
    <div class="c-profile-insights mb-4">

        <div class="c-profile-insight d-flex flex-column align-items-start gap-1">
            <div class="c-profile-insight__value d-flex align-items-center gap-2">
                @if (Model.ReviewCount > 0)
                {
                    <span>@Model.AverageRating.ToString("0.0")</span>
                    <span class="c-profile-insight__star">&#9733;</span>
                }
                else
                {
                    <span class="c-profile-insight__empty">—</span>
                }
            </div>
            <span class="c-profile-insight__label">Avg. Rate Given</span>
        </div>

        <div class="c-profile-insight d-flex flex-column align-items-start gap-1">
            <div class="c-profile-insight__value c-profile-insight__value--category d-flex align-items-center gap-2">
                @if (!string.IsNullOrEmpty(Model.MostReviewedCategory))
                {
                    var topSlug = Model.MostReviewedCategory.ToLowerInvariant().Replace(" ", "");
                    <span class="c-profile-cat-color--@topSlug">@Model.MostReviewedCategory</span>
                }
                else
                {
                    <span class="c-profile-insight__empty">—</span>
                }
            </div>
            <span class="c-profile-insight__label">Most Reviewed Category</span>
        </div>

        <div class="c-profile-insight d-flex flex-column align-items-start gap-1">
            <div class="c-profile-insight__value fs-5 d-flex align-items-center gap-2">
                @if (!string.IsNullOrEmpty(Model.HighestRatedItemName))
                {
                    <span class="text-truncate d-block">@Model.HighestRatedItemName</span>
                }
                else
                {
                    <span class="c-profile-insight__empty">—</span>
                }
            </div>
            <span class="c-profile-insight__label">Highest Rated Media</span>
        </div>

    </div>

    <!-- ── Activity by category ── -->
    <div class="c-profile-activity">
        <h2 class="c-profile-activity__title mb-4">Activity by Category</h2>

        @if (!Model.CategoryActivity.Any())
        {
            <p class="c-profile-activity__empty">No reviews yet.</p>
        }
        else
        {
            <div class="c-profile-activity__rows d-flex flex-column gap-3">
                @foreach (var cat in Model.CategoryActivity)
                {
                    <div class="c-profile-activity__row">
                        <span class="c-badge c-badge--@cat.BadgeSlug rounded-pill">@cat.CategoryName</span>
                        <div class="c-profile-bar">
                            <div class="c-profile-bar__fill c-profile-bar__fill--@cat.BadgeSlug" style="width:@cat.ActivityPercent%"></div>
                        </div>
                        <span class="c-profile-activity__count text-end">@cat.ReviewCount review@(cat.ReviewCount != 1 ? "s" : "")</span>
                    </div>
                }
            </div>
        }
    </div>

</div>
