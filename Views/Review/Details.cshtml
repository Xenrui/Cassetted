@model ReviewDetailViewModel
@{
    ViewData["Title"] = $"View Post - {Model.UserDisplayName}";
    ViewData["BodyClass"] = "cassetted-landing";
}

@section Styles {
    <link rel="stylesheet" href="~/css/review.css" asp-append-version="true" />
}

<div class="c-post-page">

    <a href="javascript:history.back()" class="c-post__back d-inline-flex align-items-center justify-content-center mb-4" aria-label="Go back">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
            <path d="M19 12H5M5 12l7 7M5 12l7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
    </a>

    <div class="c-post-card">

        <!-- ── Header ── -->
        <h2 class="c-post-card__heading">@Model.UserDisplayName's Review</h2>

        <!-- ── Review ── -->
        <div class="c-post-card__review">
            <div class="d-flex align-items-start justify-content-between mb-2">
                <div class="d-flex align-items-start gap-3">
                    <div class="c-avatar c-avatar--sm flex-shrink-0">
                        <svg viewBox="0 0 40 40" fill="none">
                            <circle cx="20" cy="20" r="20" fill="#2a5045" />
                            <circle cx="20" cy="15" r="6" fill="#3d7060" />
                            <path d="M7 36c0-7 5.8-12 13-12s13 5 13 12" fill="#3d7060" />
                        </svg>
                    </div>
                    <div class="d-flex flex-column">
                        <div class="c-review-card__meta d-flex align-items-center gap-1">
                            <a class="c-review-card__username" asp-controller="Profile" asp-action="Index" asp-route-userId="@Model.UserId">@Model.UserDisplayName</a>
                            <span class="c-review-card__sep mx-1">·</span>
                            <span class="c-review-card__date">@Model.CreatedAt.ToString("MM/dd/yyyy")</span>
                        </div>
                        <div class="c-stars mt-1">
                            @Html.Raw(new string('★', Model.FilledStars))
                            @if (Model.FilledStars < 5)
                            {
                                <span class="c-star--empty">@Html.Raw(new string('★', 5 - Model.FilledStars))</span>
                            }
                        </div>
                    </div>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <span class="c-badge c-badge--@Model.BadgeSlug rounded-pill">@Model.CategoryName</span>
                    @if (Model.IsOwnReview)
                    {
                        <div class="dropdown">
                            <button class="c-post-card__menu" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Options">&#8942;</button>
                            <ul class="dropdown-menu dropdown-menu-end c-post-card__dropdown">
                                <li><a class="dropdown-item" asp-action="Edit" asp-route-id="@Model.Id">Edit</a></li>
                                <li>
                                    <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item c-post-card__dropdown-delete">Delete</button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    }
                </div>
            </div>

            <h3 class="c-review-card__title">@Model.ItemName</h3>
            <p class="c-review-card__body">@Model.Body</p>

            <div class="c-review-card__actions d-flex gap-1">
                <button class="c-action-btn c-like-btn d-inline-flex align-items-center gap-2 @(Model.IsLikedByCurrentUser ? "c-like-btn--liked" : "")"
                        data-review-id="@Model.Id">
                    <svg class="c-like-btn__icon" width="16" height="16" viewBox="0 0 24 24" fill="@(Model.IsLikedByCurrentUser ? "currentColor" : "none")">
                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    Like<span class="c-like-count">@(Model.LikeCount > 0 ? $" · {Model.LikeCount}" : "")</span>
                </button>
                <button class="c-action-btn c-fav-btn d-inline-flex align-items-center gap-2 @(Model.IsFavoritedByCurrentUser ? "c-fav-btn--saved" : "")"
                        data-review-id="@Model.Id">
                    <svg class="c-fav-btn__icon" width="16" height="16" viewBox="0 0 24 24" fill="@(Model.IsFavoritedByCurrentUser ? "currentColor" : "none")">
                        <path d="M6 3h12a1 1 0 0 1 1 1v17l-7-4-7 4V4a1 1 0 0 1 1-1z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
                    </svg>
                    Save<span class="c-fav-count">@(Model.FavoriteCount > 0 ? $" · {Model.FavoriteCount}" : "")</span>
                </button>
                <button class="c-action-btn d-inline-flex align-items-center gap-2">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    Reply@(Model.Comments.Count > 0 ? $" · {Model.Comments.Count}" : "")
                </button>
            </div>
        </div>

        <!-- ── Comments ── -->
        <div class="c-post-card__comments">
            @if (!Model.Comments.Any())
            {
                <p class="text-muted small text-center py-2">No replies yet.</p>
            }
            else
            {
                @foreach (var comment in Model.Comments)
                {
                    <div class="c-comment d-flex align-items-start gap-3 mb-3">
                        <div class="c-comment__avatar">
                            <svg viewBox="0 0 40 40" fill="none">
                                <circle cx="20" cy="20" r="20" fill="#2a5045" />
                                <circle cx="20" cy="15" r="6" fill="#3d7060" />
                                <path d="M7 36c0-7 5.8-12 13-12s13 5 13 12" fill="#3d7060" />
                            </svg>
                        </div>
                        <div class="c-comment__bubble">
                            <a class="c-comment__username" asp-controller="Profile" asp-action="Index" asp-route-userId="@comment.UserId">@comment.UserDisplayName</a>
                            <p class="c-comment__body">@comment.Body</p>
                        </div>
                    </div>
                }
            }
        </div>

        <!-- ── Reply input ── -->
        <form asp-controller="Review" asp-action="AddComment" method="post" class="c-post-card__reply d-flex align-items-center gap-3">
            @Html.AntiForgeryToken()
            <input type="hidden" name="reviewId" value="@Model.Id" />
            <div class="c-comment__avatar flex-shrink-0">
                <svg viewBox="0 0 40 40" fill="none">
                    <circle cx="20" cy="20" r="20" fill="#2a5045" />
                    <circle cx="20" cy="15" r="6" fill="#3d7060" />
                    <path d="M7 36c0-7 5.8-12 13-12s13 5 13 12" fill="#3d7060" />
                </svg>
            </div>
            <input type="text" name="body" class="c-post-card__reply-input" placeholder="Write a reply..." maxlength="1000" />
            <button type="submit" class="c-post-card__reply-btn">Reply</button>
        </form>

    </div>
</div>
