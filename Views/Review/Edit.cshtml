@model EditReviewViewModel
@{
    ViewData["Title"] = "Edit Review";
    ViewData["BodyClass"] = "cassetted-landing";
}

@section Styles {
    <link rel="stylesheet" href="~/css/review.css" asp-append-version="true" />
}

<div class="c-post-page">

    <a href="javascript:history.back()" class="c-post__back d-inline-flex align-items-center justify-content-center mb-4" aria-label="Go back">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
            <path d="M19 12H5M5 12l7 7M5 12l7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
    </a>

    <div class="c-post-card">
        <div class="c-post-card__heading d-flex align-items-center justify-content-center gap-2">
            <span>Edit Review</span>
            <span class="c-badge c-badge--@Model.BadgeSlug rounded-pill">@Model.CategoryName</span>
        </div>

        <form asp-controller="Review" asp-action="Edit" asp-route-id="@Model.ReviewId" method="post" class="c-edit-form p-4">
            @Html.AntiForgeryToken()

            <div class="c-edit-form__item-name mb-4">@Model.ItemName</div>

            <div class="c-edit-form__field mb-4">
                <label class="c-edit-form__label d-block mb-2">Rating</label>
                <div class="c-edit-stars d-flex gap-1 mb-1" id="editStarPicker">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <span class="c-edit-star @(i <= Model.Input.Rating ? "c-edit-star--filled" : "")" data-val="@i">&#9733;</span>
                    }
                </div>
                <input type="hidden" name="Rating" id="editRatingInput" value="@Model.Input.Rating" />
                <span class="text-danger field-validation-error">@Html.ValidationMessage("Rating")</span>
            </div>

            <div class="c-edit-form__field mb-4">
                <label class="c-edit-form__label d-block mb-2" for="editBody">Review</label>
                <textarea name="Body" id="editBody" class="c-edit-form__textarea" rows="6" maxlength="2000">@Model.Input.Body</textarea>
                <span class="text-danger field-validation-error">@Html.ValidationMessage("Body")</span>
            </div>

            <div class="c-edit-form__field d-flex align-items-center gap-2 mb-4">
                @Html.CheckBox("IsFavorited", Model.Input.IsFavorited, new { id = "editFavorited" })
                <label for="editFavorited" class="c-edit-form__check-label">Mark as favorite</label>
            </div>

            <div class="c-edit-form__actions d-flex justify-content-end align-items-center gap-3 mt-4 pt-4">
                <a href="javascript:history.back()" class="c-edit-form__cancel">Cancel</a>
                <button type="submit" class="c-edit-form__save">Save Changes</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    const stars = document.querySelectorAll('.c-edit-star');
    const input = document.getElementById('editRatingInput');

    function highlightStars(n) {
        stars.forEach(s => s.classList.toggle('c-edit-star--filled', +s.dataset.val <= n));
    }

    stars.forEach(star => {
        star.addEventListener('mouseenter', () => highlightStars(+star.dataset.val));
        star.addEventListener('mouseleave', () => highlightStars(+input.value));
        star.addEventListener('click', () => {
            input.value = star.dataset.val;
            highlightStars(+input.value);
        });
    });
</script>
}
