@using Microsoft.AspNetCore.Identity
@using System.Security.Claims
@inject SignInManager<Cassetted.Models.ApplicationUser> SignInManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Cassetted</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@300;400;600&family=Outfit:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Cassetted.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="@(ViewData["BodyClass"])">

    @{
        var activeNav = ViewData["ActiveNav"]?.ToString() ?? "";
    }
    <nav class="c-nav">
        <div class="c-nav__inner d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center gap-4">
                <a href="/" class="c-nav__logo-link">
                    <img src="~/images/logo.png" alt="Cassetted" class="c-nav__logo" />
                </a>
                <div class="d-flex align-items-center gap-3">
                    <a href="/Feed" class="c-nav__link @(activeNav == "Feed" ? "c-nav__link--active" : "")">Feed</a>
                    <div class="position-relative">
                        <a href="/Browse" class="c-nav__link @(activeNav == "Browse" ? "c-nav__link--active" : "")">
                            Browse
                            <svg class="c-nav__chevron" width="12" height="12" viewBox="0 0 12 12" fill="none">
                                <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                        </a>
                    </div>
                    <a href="/Library" class="c-nav__link @(activeNav == "Library" ? "c-nav__link--active" : "")">Library</a>
                </div>
            </div>
            <div class="d-flex align-items-center gap-2">
                <div class="c-nav__search d-flex align-items-center gap-2">
                    <svg class="c-nav__search-icon" width="15" height="15" viewBox="0 0 16 16" fill="none">
                        <circle cx="6.5" cy="6.5" r="4.5" stroke="#999" stroke-width="1.5" />
                        <path d="M10.5 10.5l3 3" stroke="#999" stroke-width="1.5" stroke-linecap="round" />
                    </svg>
                    <input type="search" class="c-nav__search-input" placeholder="Search titles, users, reviews..." />
                </div>
                @if (SignInManager.IsSignedIn(User))
                {
                    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
                    <div class="dropdown">
                        <button class="c-nav__user-btn c-nav__user-btn--auth d-flex align-items-center justify-content-center"
                                data-bs-toggle="dropdown" aria-expanded="false" aria-label="Account menu">
                            <svg width="21" height="21" viewBox="0 0 24 24" fill="none">
                                <circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="1.8" />
                                <path d="M4 20c0-4 3.582-7 8-7s8 3 8 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                            </svg>
                            <span class="c-nav__user-dot"></span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end c-nav__dropdown">
                            <li>
                                <a class="c-nav__dropdown-item" asp-controller="Profile" asp-action="Index" asp-route-userId="@currentUserId">
                                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none">
                                        <circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="1.7" />
                                        <path d="M4 20c0-4 3.582-7 8-7s8 3 8 7" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
                                    </svg>
                                    Profile
                                </a>
                            </li>
                            <li>
                                <a class="c-nav__dropdown-item" asp-controller="Profile" asp-action="Settings">
                                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none">
                                        <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.7" />
                                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" stroke="currentColor" stroke-width="1.7" />
                                    </svg>
                                    Settings
                                </a>
                            </li>
                            <li><hr class="dropdown-divider c-nav__dropdown-divider" /></li>
                            <li>
                                <form asp-area="Identity" asp-page="/Account/Logout"
                                      asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="c-nav__dropdown-item c-nav__dropdown-item--danger">
                                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none">
                                            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4M16 17l5-5-5-5M21 12H9" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
                                        </svg>
                                        Sign out
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                    <a href="/Identity/Account/Login" class="c-nav__user-btn d-flex align-items-center justify-content-center" aria-label="Account">
                        <svg width="21" height="21" viewBox="0 0 24 24" fill="none">
                            <circle cx="12" cy="8" r="4" stroke="#2a2a2a" stroke-width="1.8" />
                            <path d="M4 20c0-4 3.582-7 8-7s8 3 8 7" stroke="#2a2a2a" stroke-width="1.8" stroke-linecap="round" />
                        </svg>
                    </a>
                }
            </div>
        </div>
    </nav>

    <main class="flex-grow-1">
        @RenderBody()
    </main>

    <footer class="c-footer">
        <div class="container text-center">
            &copy; 2026 Cassetted &mdash; <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
