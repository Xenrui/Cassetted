<div class="modal fade" id="reviewModal" tabindex="-1" aria-labelledby="reviewModalLabel" aria-hidden="true">
    <div class="modal-dialog c-review-modal-dialog">
        <div class="modal-content c-review-modal">
            <div class="modal-body p-0">

                <div class="c-review-modal__header position-relative text-center">
                    <h5 class="c-review-modal__title" id="reviewModalLabel">Create a Review</h5>
                    <button type="button" class="c-review-modal__close position-absolute"
                            data-bs-dismiss="modal" aria-label="Close">&#x2715;</button>
                </div>

                <form id="reviewForm" class="c-review-modal__body d-flex flex-column gap-3">
                    @Html.AntiForgeryToken()

                    <div class="c-review-modal__field d-flex flex-column gap-2">
                        <label class="c-review-modal__label">Category</label>
                        <select class="c-review-modal__select" id="reviewCategory" name="CategoryId">
                            <option value="" disabled selected>Select Category</option>
                            <option value="1">Movies</option>
                            <option value="2">TV Shows</option>
                            <option value="3">Music</option>
                            <option value="4">Books</option>
                            <option value="5">Anime</option>
                            <option value="6">Games</option>
                        </select>
                    </div>

                    <div class="c-review-modal__field d-flex flex-column gap-2 position-relative">
                        <label class="c-review-modal__label" for="reviewTitle">Title</label>
                        <input type="text" class="c-review-modal__input" id="reviewTitle" name="ItemName" autocomplete="off" />
                        <input type="hidden" id="reviewItemId" name="ItemId" />
                        <ul class="c-review-modal__suggestions" id="reviewSuggestions" role="listbox" hidden></ul>
                        <span class="c-review-modal__hint" id="reviewTitleHint" hidden></span>
                    </div>

                    <div class="c-review-modal__field d-flex flex-column gap-2">
                        <label class="c-review-modal__label">Rating</label>
                        <div class="c-review-modal__stars d-flex gap-1" id="modalStars">
                            <span class="c-review-modal__star" data-value="1">&#9733;</span>
                            <span class="c-review-modal__star" data-value="2">&#9733;</span>
                            <span class="c-review-modal__star" data-value="3">&#9733;</span>
                            <span class="c-review-modal__star" data-value="4">&#9733;</span>
                            <span class="c-review-modal__star" data-value="5">&#9733;</span>
                        </div>
                        <input type="hidden" id="reviewRating" name="Rating" value="0" />
                    </div>

                    <div class="c-review-modal__field d-flex flex-column gap-2">
                        <label class="c-review-modal__label">Comments</label>
                        <textarea class="c-review-modal__textarea" id="reviewComments" name="Body" rows="8"></textarea>
                    </div>

                    <p id="reviewError" class="text-danger small mb-0" aria-live="polite"></p>

                    <button type="button" class="c-review-modal__post-btn" id="reviewPostBtn">POST</button>

                </form>
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        const stars = document.querySelectorAll('.c-review-modal__star');
        const ratingInput = document.getElementById('reviewRating');
        const categorySel = document.getElementById('reviewCategory');
        const titleInput = document.getElementById('reviewTitle');
        const itemIdInput = document.getElementById('reviewItemId');
        const suggestionsList = document.getElementById('reviewSuggestions');
        const hintEl = document.getElementById('reviewTitleHint');

        function paintStars(val) {
            stars.forEach(s => s.classList.toggle('is-active', parseInt(s.dataset.value) <= val));
        }

        stars.forEach(star => {
            star.addEventListener('mouseenter', () => paintStars(parseInt(star.dataset.value)));
            star.addEventListener('mouseleave', () => paintStars(parseInt(ratingInput.value)));
            star.addEventListener('click', () => {
                ratingInput.value = star.dataset.value;
                paintStars(parseInt(ratingInput.value));
            });
        });

        // ── Typeahead ──
        let abortCtrl = null;
        let debounceTimer = null;

        function showHint(text, isError) {
            if (!text) { hintEl.hidden = true; hintEl.textContent = ''; return; }
            hintEl.hidden = false;
            hintEl.textContent = text;
            hintEl.classList.toggle('c-review-modal__hint--error', !!isError);
        }

        function hideSuggestions() {
            suggestionsList.hidden = true;
            suggestionsList.innerHTML = '';
        }

        function renderSuggestions(items) {
            if (!items.length) { hideSuggestions(); return; }
            suggestionsList.innerHTML = items.map(it => {
                const meta = `${it.reviewCount} review${it.reviewCount === 1 ? '' : 's'} · ★ ${it.averageRating.toFixed(1)}`;
                return `<li class="c-review-modal__suggestion" data-id="${it.id}" data-name="${it.name.replace(/"/g, '&quot;')}">
                    <span class="c-review-modal__suggestion__name">${escapeHtml(it.name)}</span>
                    <span class="c-review-modal__suggestion__meta">${meta}</span>
                </li>`;
            }).join('');
            suggestionsList.hidden = false;
        }

        function escapeHtml(s) {
            return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
        }

        async function fetchSuggestions(categoryId, q) {
            if (abortCtrl) abortCtrl.abort();
            abortCtrl = new AbortController();
            try {
                const url = `/Review/SearchItems?categoryId=${encodeURIComponent(categoryId)}&q=${encodeURIComponent(q)}`;
                const res = await fetch(url, { signal: abortCtrl.signal });
                if (!res.ok) return;
                const items = await res.json();
                renderSuggestions(items);
            } catch (e) {
                if (e.name !== 'AbortError') hideSuggestions();
            }
        }

        titleInput.addEventListener('input', () => {
            itemIdInput.value = '';
            showHint('');
            const q = titleInput.value.trim();
            const categoryId = categorySel.value;
            if (!categoryId) { showHint('Pick a category first.'); hideSuggestions(); return; }
            if (q.length < 2) { hideSuggestions(); return; }
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(() => fetchSuggestions(categoryId, q), 220);
        });

        suggestionsList.addEventListener('click', e => {
            const li = e.target.closest('.c-review-modal__suggestion');
            if (!li) return;
            titleInput.value = li.dataset.name;
            itemIdInput.value = li.dataset.id;
            hideSuggestions();
            showHint('Linked to an existing item.');
        });

        categorySel.addEventListener('change', () => {
            itemIdInput.value = '';
            hideSuggestions();
            showHint('');
        });

        document.addEventListener('click', e => {
            if (e.target === titleInput || suggestionsList.contains(e.target)) return;
            hideSuggestions();
        });

        document.getElementById('reviewPostBtn').addEventListener('click', async function () {
            const errorEl = document.getElementById('reviewError');
            errorEl.textContent = '';

            const categoryVal = document.getElementById('reviewCategory').value;
            const itemName = document.getElementById('reviewTitle').value.trim();
            const ratingVal = ratingInput.value;
            const body = document.getElementById('reviewComments').value.trim();

            if (!categoryVal) { errorEl.textContent = 'Please select a category.'; return; }
            if (!itemName) { errorEl.textContent = 'Please enter a title.'; return; }
            if (!ratingVal || ratingVal === '0') { errorEl.textContent = 'Please select a rating.'; return; }
            if (!body) { errorEl.textContent = 'Please write a comment.'; return; }

            const btn = this;
            btn.disabled = true;
            btn.textContent = 'Posting...';

            try {
                const response = await fetch('/Review/Create', {
                    method: 'POST',
                    body: new FormData(document.getElementById('reviewForm'))
                });
                const result = await response.json();

                if (result.success) {
                    bootstrap.Modal.getInstance(document.getElementById('reviewModal')).hide();
                } else {
                    errorEl.textContent = result.errors?.[0] ?? 'Something went wrong.';
                }
            } catch {
                errorEl.textContent = 'An error occurred. Please try again.';
            } finally {
                btn.disabled = false;
                btn.textContent = 'POST';
            }
        });

        const reviewModal = document.getElementById('reviewModal');
        if (reviewModal) {
            reviewModal.addEventListener('hidden.bs.modal', function () {
                categorySel.value = '';
                titleInput.value = '';
                itemIdInput.value = '';
                document.getElementById('reviewComments').value = '';
                ratingInput.value = '0';
                paintStars(0);
                hideSuggestions();
                showHint('');
                document.getElementById('reviewError').textContent = '';
            });
        }
    })();
</script>
